# Schnelles lokales Dockerfile — kopiert das vorher mit
#   sbt controller/assembly
# gebaute Fat-JAR direkt rein. Kein sbt/download im Container.
FROM eclipse-temurin:21-jre-alpine
RUN apk add --no-cache curl
WORKDIR /app
COPY controller/target/scala-3.6.4/alu-chess-controller-assembly-0.1.0-SNAPSHOT.jar app.jar
EXPOSE 8081
ENV PORT=8081
ENTRYPOINT ["java", "-jar", "app.jar"]
