# DB_TYPE bestimmt welche Datenbank verwendet wird.
# Werte: memory | postgres | mongo
# Kopiere diese Datei nach .env und passe die Werte an.

DB_TYPE=postgres

# ── Frontend ────────────────────────────────────────────────────
# Pfad zum alu-chess-web Repo (relativ zu diesem docker-compose.yml oder absolut)
FRONTEND_CONTEXT=../../SoftwarearchitekturWeb/alu-chess-web

# ── PostgreSQL (DB_TYPE=postgres) ──────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/chess
DB_USER=Username
DB_PASSWORD=Password

# ── MongoDB (DB_TYPE=mongo) ────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=Username
